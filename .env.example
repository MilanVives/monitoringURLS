# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/monitoring

# Admin password for admin panel
ADMIN_PASSWORD=admin123

# Session secret for authentication
SESSION_SECRET=change-this-to-a-random-secret-in-production

# Check interval in milliseconds (default: 300000 = 5 minutes)
# Examples: 300000 (5 min), 600000 (10 min), 1200000 (20 min)
CHECK_INTERVAL=300000

# Cloudflare Tunnel Token (optional - for production deployment)
# Get your token from: https://one.dash.cloudflare.com/
# Navigate to: Access > Tunnels > Create/Edit Tunnel
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here
